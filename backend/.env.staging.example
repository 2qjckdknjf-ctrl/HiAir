# HiAir backend environment template for staging/production-like deployments.
# Do not commit real secrets. Copy to .env and fill with secure values.
#
# Secret generation examples:
# - openssl rand -hex 32
# - python3 -c "import secrets; print(secrets.token_urlsafe(48))"

# Core
DATABASE_URL=postgresql://hiair:<password>@<host>:5432/hiair
JWT_SECRET=<min-32-byte-random-secret>
JWT_ALGORITHM=HS256
ACCESS_TOKEN_TTL_MINUTES=120
APP_ENV=staging
ALLOW_LEGACY_USER_HEADER_AUTH=false

# Subscriptions
# Current supported values: stub, stripe
SUBSCRIPTION_PROVIDER=stub
# Required for non-stub providers and recommended whenever webhook is exposed.
SUBSCRIPTION_WEBHOOK_SECRET=<long-random-webhook-secret>

# Environmental data providers
# openweathermap + waqi (API key mode) OR openmeteo (no key mode)
WEATHER_API_PROVIDER=openweathermap
WEATHER_API_KEY=<weather-provider-api-key>
AQI_API_PROVIDER=waqi
AQI_API_KEY=<aqi-provider-api-key>
# Alternative keyless providers:
# WEATHER_API_PROVIDER=openmeteo
# AQI_API_PROVIDER=openmeteo

# Notifications adapters
# stub for dry-run, live for real delivery
NOTIFICATIONS_PROVIDER_MODE=stub
NOTIFICATION_ADMIN_TOKEN=<random-admin-token-min-16>
NOTIFICATION_MAX_ATTEMPTS=3
NOTIFICATION_RETRY_BACKOFF_MS=300
NOTIFICATION_SECRET_ROTATION_DAYS=30
RETENTION_NOTIFICATION_DELIVERY_ATTEMPTS_DAYS=90
RETENTION_NOTIFICATION_EVENTS_DAYS=180
RETENTION_SUBSCRIPTION_WEBHOOK_EVENTS_DAYS=180
RETENTION_SECRET_ROTATION_EVENTS_DAYS=365

# FCM/APNs credentials (needed when NOTIFICATIONS_PROVIDER_MODE=live)
FCM_SERVER_KEY=
FCM_PROJECT_ID=
FCM_CLIENT_EMAIL=
FCM_PRIVATE_KEY=
APNS_AUTH_TOKEN=
APNS_TOPIC=
APNS_TEAM_ID=
APNS_KEY_ID=
APNS_PRIVATE_KEY=

# Secret source (env | file | http | vault)
SECRET_SOURCE=env
SECRET_FILE_PATH=
SECRET_HTTP_URL=
SECRET_HTTP_TOKEN=
SECRET_HTTP_TIMEOUT_MS=4000
SECRET_CACHE_TTL_SECONDS=60
VAULT_ADDR=
VAULT_TOKEN=
VAULT_NAMESPACE=
VAULT_KV_MOUNT=secret
VAULT_KV_PATH=hiair
