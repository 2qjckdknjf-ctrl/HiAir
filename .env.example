# Backend
DATABASE_URL=postgresql://hiair:hiair@localhost:5432/hiair
JWT_SECRET=replace-with-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_TTL_MINUTES=120
APP_ENV=development
ALLOW_LEGACY_USER_HEADER_AUTH=false
SUBSCRIPTION_PROVIDER=stub
SUBSCRIPTION_WEBHOOK_SECRET=

# Data providers (defaulted for MVP)
WEATHER_API_PROVIDER=openweathermap
WEATHER_API_KEY=
AQI_API_PROVIDER=waqi
AQI_API_KEY=
# Optional no-key providers:
# WEATHER_API_PROVIDER=openmeteo
# AQI_API_PROVIDER=openmeteo

# Optional LLM explanation layer
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1/chat/completions
OPENAI_PROMPT_VERSION=hiair-expl-v1

# Notifications adapters
NOTIFICATIONS_PROVIDER_MODE=stub
FCM_SERVER_KEY=
FCM_PROJECT_ID=
FCM_CLIENT_EMAIL=
FCM_PRIVATE_KEY=
APNS_AUTH_TOKEN=
APNS_TOPIC=
APNS_TEAM_ID=
APNS_KEY_ID=
APNS_PRIVATE_KEY=
NOTIFICATION_MAX_ATTEMPTS=3
NOTIFICATION_RETRY_BACKOFF_MS=300
NOTIFICATION_SECRET_ROTATION_DAYS=30
NOTIFICATION_ADMIN_TOKEN=
RETENTION_NOTIFICATION_DELIVERY_ATTEMPTS_DAYS=90
RETENTION_NOTIFICATION_EVENTS_DAYS=180
RETENTION_SUBSCRIPTION_WEBHOOK_EVENTS_DAYS=180
RETENTION_SECRET_ROTATION_EVENTS_DAYS=365

# Secret source (env | file | http | vault)
SECRET_SOURCE=env
SECRET_FILE_PATH=
SECRET_HTTP_URL=
SECRET_HTTP_TOKEN=
SECRET_HTTP_TIMEOUT_MS=4000
SECRET_CACHE_TTL_SECONDS=60
VAULT_ADDR=
VAULT_TOKEN=
VAULT_NAMESPACE=
VAULT_KV_MOUNT=secret
VAULT_KV_PATH=hiair
